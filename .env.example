# Knowledge Vault Environment Variables
# Copy this to .env.local and customize for your machine

# Vault root path
VAULT_ROOT=/path/to/your/knowledge-vault

# External repositories path (where your synced source repos live)
EXTERNAL_REPOS=/path/to/your/external-repos

# Example: source repositories to sync wiki patterns from
# Rename these to match your own repos
REPO_A=${EXTERNAL_REPOS}/example-repo-a
REPO_B=${EXTERNAL_REPOS}/example-repo-b
REPO_C=${EXTERNAL_REPOS}/example-repo-c
